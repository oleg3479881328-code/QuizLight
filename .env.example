# DeepSeek API
# https://platform.deepseek.com/api_keys
#
# 1. Create an API key at https://platform.deepseek.com/api_keys
# 2. Fill in the value below and rename this file to .env.local
#
# Model: deepseek-chat (non-thinking mode)
# Provider policy: DeepSeek API -> local fallback

DEEPSEEK_API_KEY=

# ─── Azure Translator Text API v3.0 (deferred compatibility) ─────────────────
# https://learn.microsoft.com/en-us/azure/ai-services/translator/text-translation/reference/v3/translate
#
# Azure Translator is preserved but not configured or called by default.
# To re-enable: set the values below and update vite.config.ts to register
# the azure-translator-dev-proxy plugin before deepseek-dev-proxy.
#
# AZURE_TRANSLATOR_KEY=
# AZURE_TRANSLATOR_REGION=
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
